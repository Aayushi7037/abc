"""MultiIndex for Columns"""

import pandas as pd
import numpy as np

index = pd.MultiIndex.from_product(
    [[2015, 2016], [1, 2]],
    names=['year', 'Quarter']
)

columns = pd.MultiIndex.from_product(
    [['Brijesh', 'Himmat', 'Surender'],
     ['Domestic', 'Commercial']],
    names=['Employee', 'type']
)

data = np.round(np.random.randn(4, 6), 1)

call_data = pd.DataFrame(data, index=index, columns=columns)
call_data

call_data['Himmat', 'Domestic']

call_data['Himmat', 'Domestic']

call_data.loc[(2015, 1), ('Brijesh', 'Commercial')]

call_data.iloc[:2, :2]

call_data.loc[:, ('Himmat', 'Domestic')]

a = call_data.loc[(2015, 1), ('Brijesh', 'Commercial')]
a

call_data.iloc[:2, :2]

import pandas as pd

data = {
    'Name': ['Amritsar', 'Bathinda', 'Hoshiarpur', 'Jalandhar', 'Ludhiana'],
    '_Area': [2647, 3385, 3365, 2632, 3767],
    'Population': [2490656, 1388525, 1586625, 2193590, 3487399]
}

df = pd.DataFrame(data)
print(df)

for column, values in df.iteritems():
    print(column)
    print(values)

for column, values in df.iteritems():
    print(column)
    print(values)

for index, row in df.iterrows():
    print(index, row['Name'], row['Population'])

for row in df.itertuples():
    print(row.Name, row.Population)

"""sorting"""

df_sorted_index = df.sort_index()
print(df_sorted_index)

df.sort_values(by='Area')

df.sort_values(by='Population', ascending=False)

df.sort_index(axis=1)

